---
import BaseLayout from '../layouts/BaseLayout.astro';
import SessionCard from '../components/SessionCard.astro';
import { getCollection } from 'astro:content';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const sessions = await getCollection('sessions');
const sorted = sessions.sort((a, b) => a.data.number - b.data.number);
const weeks = [1, 2, 3, 4, 5, 6];
---

<BaseLayout title="커리큘럼">
  <section class="py-12">
    <p class="font-mono text-accent text-xs tracking-widest uppercase mb-4">Curriculum</p>
    <h1 class="font-mono text-2xl md:text-4xl font-bold mb-6">커리큘럼</h1>
    <p class="text-text-secondary text-base leading-relaxed max-w-3xl">
      6주 12세션으로 구성된 AI Agent 리터러시 과정입니다. 매주 개념 세션과 실습 세션이 교차 진행됩니다.
    </p>
  </section>

  <!-- No coding banner -->
  <section class="mb-10">
    <div class="bg-accent/5 border border-accent/20 rounded-card p-5 flex items-start gap-4">
      <span class="font-mono text-accent text-lg font-bold flex-shrink-0 mt-0.5">*</span>
      <div>
        <p class="text-text-primary font-semibold text-sm mb-1">코딩 경험이 필요하지 않습니다</p>
        <p class="text-text-muted text-xs leading-relaxed">
          이 세미나는 전 직원을 대상으로 합니다. 실습은 웹 기반 도구(Cowork)로 진행되며, 코드 작성이 아닌 AI 운영 개념을 배웁니다.
          프로그래밍 경험이 없어도 모든 세션에 참여할 수 있습니다.
        </p>
      </div>
    </div>
  </section>

  <!-- Weekly sessions -->
  {weeks.map((week) => {
    const weekSessions = sorted.filter((s) => s.data.week === week);
    const weekTheme = weekSessions[0]?.data.weekTheme;
    return (
      <section class="mb-12">
        <div class="flex items-center gap-3 mb-5">
          <span class="font-mono text-xs text-accent bg-accent/10 px-2 py-1 rounded-btn">Week {week}</span>
          <h2 class="font-mono text-sm md:text-base font-semibold text-text-primary">{weekTheme}</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-4">
          {weekSessions.map((session) => (
            <SessionCard
              number={session.data.number}
              title={session.data.title}
              type={session.data.type}
              mission={session.data.mission}
              level={session.data.level}
              keyMessage={session.data.keyMessage}
              deliverable={session.data.deliverable}
              status={session.data.status}
            />
          ))}
        </div>
      </section>
    );
  })}
</BaseLayout>
