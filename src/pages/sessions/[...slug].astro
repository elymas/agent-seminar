---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const sessions = await getCollection('sessions');
  return sessions.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';

const allSessions = await getCollection('sessions');
const sorted = allSessions.sort((a, b) => a.data.number - b.data.number);
const currentIndex = sorted.findIndex((s) => s.id === entry.id);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;

const { number, title, week, weekTheme, type, mission, level, keyMessage, deliverable, timeStructure, status, bookRef } = entry.data;

const typeLabel: Record<string, string> = { concept: '개념', practice: '실습', special: '특별' };
const typeColor: Record<string, string> = {
  concept: 'bg-blue-500/10 text-blue-400 border-blue-500/20',
  practice: 'bg-accent/10 text-accent border-accent/20',
  special: 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20',
};
const statusLabel: Record<string, string> = { completed: '완료', current: '진행중', upcoming: '예정' };
---

<BaseLayout title={`#${number.toString().padStart(2, '0')} ${title}`}>
  <!-- Breadcrumb -->
  <nav class="mb-8 text-xs font-mono text-text-muted" aria-label="Breadcrumb">
    <a href={`${base}curriculum/`} class="hover:text-accent transition-colors">커리큘럼</a>
    <span class="mx-2">/</span>
    <span class="text-text-secondary">Week {week}</span>
    <span class="mx-2">/</span>
    <span class="text-text-primary">세션 {number.toString().padStart(2, '0')}</span>
  </nav>

  <!-- Session Header -->
  <header class="mb-10">
    <div class="flex flex-wrap items-center gap-3 mb-4">
      <span class="font-mono text-text-muted text-sm">#{number.toString().padStart(2, '0')}</span>
      <span class={`text-xs px-2 py-0.5 rounded-btn font-mono border ${typeColor[type]}`}>
        {typeLabel[type]}
      </span>
      <span class="text-xs font-mono text-text-muted">{level}</span>
      {status === 'current' && (
        <span class="text-xs px-2 py-0.5 rounded-btn bg-accent/20 text-accent font-mono animate-pulse">
          {statusLabel[status]}
        </span>
      )}
    </div>

    <h1 class="font-mono text-2xl md:text-3xl font-bold text-text-primary leading-tight mb-3">
      {title}
    </h1>

    <p class="text-text-secondary text-sm md:text-base leading-relaxed max-w-3xl">
      {keyMessage}
    </p>
  </header>

  <!-- Meta Cards -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-10">
    <div class="bg-bg-card rounded-card p-4">
      <p class="font-mono text-accent text-[10px] tracking-widest uppercase mb-1">WEEK</p>
      <p class="text-text-primary text-sm font-semibold">{week}주차</p>
      <p class="text-text-muted text-xs mt-0.5">{weekTheme}</p>
    </div>
    <div class="bg-bg-card rounded-card p-4">
      <p class="font-mono text-accent text-[10px] tracking-widest uppercase mb-1">TIME</p>
      <p class="text-text-primary text-sm font-semibold">30분</p>
      <p class="text-text-muted text-xs mt-0.5">{timeStructure}</p>
    </div>
    <div class="bg-bg-card rounded-card p-4">
      <p class="font-mono text-accent text-[10px] tracking-widest uppercase mb-1">DELIVERABLE</p>
      <p class={`text-sm font-semibold ${deliverable !== '없음' ? 'text-accent' : 'text-text-muted'}`}>
        {deliverable}
      </p>
    </div>
    {bookRef && (
      <div class="bg-bg-card rounded-card p-4">
        <p class="font-mono text-accent text-[10px] tracking-widest uppercase mb-1">REFERENCE</p>
        <p class="text-text-muted text-xs">{bookRef}</p>
      </div>
    )}
  </div>

  {mission && (
    <div class="bg-accent/5 border border-accent/20 rounded-card p-5 mb-10">
      <p class="font-mono text-accent text-xs tracking-widest uppercase mb-2">MISSION</p>
      <p class="text-text-primary text-sm font-semibold">{mission}</p>
    </div>
  )}

  <!-- Session Content -->
  <article class="prose prose-invert prose-sm max-w-none
    prose-headings:font-mono prose-headings:text-text-primary prose-headings:font-semibold
    prose-h2:text-lg prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-bg-hover prose-h2:pb-2
    prose-h3:text-base prose-h3:mt-6 prose-h3:mb-3
    prose-p:text-text-secondary prose-p:leading-relaxed prose-p:text-sm
    prose-li:text-text-secondary prose-li:text-sm
    prose-strong:text-text-primary
    prose-code:text-accent prose-code:bg-bg-card prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-btn prose-code:text-xs prose-code:font-mono
    prose-pre:bg-bg-card prose-pre:border prose-pre:border-bg-hover prose-pre:rounded-card prose-pre:text-xs
    prose-a:text-accent prose-a:no-underline hover:prose-a:text-accent-hover
    prose-ul:my-3 prose-ol:my-3
    prose-blockquote:border-accent prose-blockquote:text-text-muted
  ">
    <Content />
  </article>

  <!-- Prev / Next Navigation -->
  <nav class="mt-16 pt-8 border-t border-bg-hover grid grid-cols-2 gap-4" aria-label="세션 탐색">
    {prev ? (
      <a href={`${base}sessions/${prev.id}/`} class="group bg-bg-card rounded-card p-4 hover:bg-bg-hover transition-colors">
        <p class="font-mono text-xs text-text-muted mb-1">&larr; 이전 세션</p>
        <p class="text-text-primary text-sm font-mono font-semibold group-hover:text-accent transition-colors">
          #{prev.data.number.toString().padStart(2, '0')} {prev.data.title}
        </p>
      </a>
    ) : <div />}
    {next ? (
      <a href={`${base}sessions/${next.id}/`} class="group bg-bg-card rounded-card p-4 hover:bg-bg-hover transition-colors text-right">
        <p class="font-mono text-xs text-text-muted mb-1">다음 세션 &rarr;</p>
        <p class="text-text-primary text-sm font-mono font-semibold group-hover:text-accent transition-colors">
          #{next.data.number.toString().padStart(2, '0')} {next.data.title}
        </p>
      </a>
    ) : (
      <a href={`${base}curriculum/`} class="group bg-bg-card rounded-card p-4 hover:bg-bg-hover transition-colors text-right">
        <p class="font-mono text-xs text-text-muted mb-1">돌아가기</p>
        <p class="text-text-primary text-sm font-mono font-semibold group-hover:text-accent transition-colors">
          커리큘럼 전체 보기
        </p>
      </a>
    )}
  </nav>
</BaseLayout>
